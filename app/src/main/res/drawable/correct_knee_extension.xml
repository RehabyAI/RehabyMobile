<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#ECFDF5"
                android:startColor="#D1FAE5"
                android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp"
        android:top="12dp"
        android:drawable="@drawable/ic_knee_extension" />
</layer-list>
